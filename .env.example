# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&connection_limit=1"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-32+-char-random-secret"
NEXTAUTH_URL="https://knittingbridge.com"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email (magic links) ──────────────────────────────────────────────────────
EMAIL_SERVER="smtp://user:password@smtp.host:587"
EMAIL_FROM="noreply@knittingbridge.com"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Daily.co (video) ─────────────────────────────────────────────────────────
DAILY_API_KEY="your-daily-api-key"
DAILY_DOMAIN="knittingbridge.daily.co"

# ─── Pusher (real-time) ───────────────────────────────────────────────────────
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"

# ─── OpenRouter (AI gateway) ──────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_MODEL="anthropic/claude-sonnet-4-20250514"
OPENROUTER_IMAGE_MODEL="openai/dall-e-3"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── Supabase (storage + db) ──────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Dev only — remove before production launch ───────────────────────────────
SITE_PASSWORD="replace-with-dev-password"
